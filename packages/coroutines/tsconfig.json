{
  "compilerOptions": {
    "lib": ["es2017"],
    "target": "es2017",
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "allowUnreachableCode": true,
    "types": ["jest"]
  }
}
