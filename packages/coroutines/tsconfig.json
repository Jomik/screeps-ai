{
  "compilerOptions": {
    "lib": ["es2024"],
    "target": "es2024",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "allowUnreachableCode": false,
    "types": []
  },
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"]
}
