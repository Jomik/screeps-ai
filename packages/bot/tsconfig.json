{
  "compilerOptions": {
    "lib": ["es2017", "es2019.Array"],
    "target": "es2017",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "allowUnreachableCode": false,
    "types": ["lodash", "screeps"]
  },
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "test/**/*.ts"]
}
